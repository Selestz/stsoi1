<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AvaloniaApp.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
        x:Class="AvaloniaApp.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        DragDrop.AllowDrop="True"
        Title="СЦОИ" Width="1200" Height="800">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid ColumnDefinitions="450, *">
        <!-- Settings Panel -->
        <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="0,0,1,0" Padding="15">
            <Grid RowDefinitions="Auto, *, Auto, Auto">
                <StackPanel Grid.Row="0" Spacing="10" Margin="0,0,0,10">
                    <TextBlock Text="Слои (снизу вверх)" FontWeight="Bold" FontSize="18"/>
                    <Button Content="+ Добавить изображение(я)..." Command="{Binding AddLayerCommand}" HorizontalAlignment="Stretch" Background="#1c75bc" Foreground="White" FontWeight="Bold"/>

                    <Border BorderBrush="#444" BorderThickness="1" CornerRadius="5" Padding="10" Background="#111">
                        <StackPanel Spacing="5">
                            <CheckBox Content="Включить фильтрацию" IsChecked="{Binding IsFilterEnabled}" FontWeight="Bold"/>
                            <StackPanel IsVisible="{Binding IsFilterEnabled}" Spacing="5" Margin="0,5,0,0">
                                <ComboBox ItemsSource="{Binding FilterMethods}" SelectedItem="{Binding SelectedFilterMethod}" HorizontalAlignment="Stretch"/>
                                <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto, Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding FilterWindowWidth, StringFormat='{}Ширина окна: {0}'}" Width="110" FontSize="12" VerticalAlignment="Center"/>
                                    <Slider Grid.Row="0" Grid.Column="1" Minimum="3" Maximum="151" TickFrequency="2" IsSnapToTickEnabled="True" Value="{Binding FilterWindowWidth}" Margin="5,0"/>
                                    
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding FilterWindowHeight, StringFormat='{}Высота окна: {0}'}" Width="110" FontSize="12" VerticalAlignment="Center"/>
                                    <Slider Grid.Row="1" Grid.Column="1" Minimum="3" Maximum="151" TickFrequency="2" IsSnapToTickEnabled="True" Value="{Binding FilterWindowHeight}" Margin="5,0"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding FilterSigma, StringFormat='{}Сигма: {0:F1}'}" Width="110" FontSize="12" VerticalAlignment="Center"/>
                                    <Slider Grid.Row="2" Grid.Column="1" Minimum="0.1" Maximum="20" TickFrequency="0.1" Value="{Binding FilterSigma}" Margin="5,0"/>
                                </Grid>
                            </StackPanel>
                            
                            <Separator Background="#333" Margin="0,5"/>

                            <CheckBox Content="Фурье-фильтрация" IsChecked="{Binding IsFourierEnabled}" FontWeight="Bold"/>
                            <StackPanel IsVisible="{Binding IsFourierEnabled}" Spacing="5" Margin="0,5,0,0">
                                <ComboBox ItemsSource="{Binding FourierFilters}" SelectedItem="{Binding SelectedFourierFilter}" HorizontalAlignment="Stretch"/>
                                <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto, Auto, Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding FourierR1, StringFormat='{}Радиус R1: {0:F0}'}" Width="110" FontSize="12" VerticalAlignment="Center"/>
                                    <Slider Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="500" Value="{Binding FourierR1}" Margin="5,0"/>
                                    
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding FourierR2, StringFormat='{}Радиус R2: {0:F0}'}" Width="110" FontSize="12" VerticalAlignment="Center"/>
                                    <Slider Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="500" Value="{Binding FourierR2}" Margin="5,0"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding FourierCx, StringFormat='{}Коорд Cx: {0}'}" Width="110" FontSize="12" VerticalAlignment="Center"/>
                                    <Slider Grid.Row="2" Grid.Column="1" Minimum="-200" Maximum="200" Value="{Binding FourierCx}" Margin="5,0"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding FourierCy, StringFormat='{}Коорд Cy: {0}'}" Width="110" FontSize="12" VerticalAlignment="Center"/>
                                    <Slider Grid.Row="3" Grid.Column="1" Minimum="-200" Maximum="200" Value="{Binding FourierCy}" Margin="5,0"/>
                                </Grid>
                            </StackPanel>

                            <Separator Background="#333" Margin="0,5"/>

                            <CheckBox Content="Включить бинаризацию" IsChecked="{Binding IsBinarizationEnabled}" FontWeight="Bold"/>
                            <StackPanel IsVisible="{Binding IsBinarizationEnabled}" Spacing="5" Margin="0,5,0,0">
                                <ComboBox ItemsSource="{Binding BinarizationMethods}" SelectedItem="{Binding SelectedBinarizationMethod}" HorizontalAlignment="Stretch"/>
                                <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding BinarizationWindowSize, StringFormat='{}Окно (a): {0}'}" Width="90" FontSize="12" VerticalAlignment="Center"/>
                                    <Slider Grid.Row="0" Grid.Column="1" Minimum="3" Maximum="151" TickFrequency="2" IsSnapToTickEnabled="True" Value="{Binding BinarizationWindowSize}" Margin="5,0"/>
                                    
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding BinarizationK, StringFormat='{}Коэфф (k): {0:F2}'}" Width="90" FontSize="12" VerticalAlignment="Center"/>
                                    <Slider Grid.Row="1" Grid.Column="1" Minimum="-1" Maximum="1" TickFrequency="0.05" IsSnapToTickEnabled="True" Value="{Binding BinarizationK}" Margin="5,0"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
                
                <!-- Layers List -->
                <ScrollViewer Grid.Row="1" Margin="0,5,0,5">
                    <ItemsControl ItemsSource="{Binding Layers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:LayerViewModel">
                                <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,10" Background="#1AFFFFFF">
                                    <Grid RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="*, *, Auto">
                                        <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Text="{Binding Name}" FontWeight="Bold" Margin="0,0,0,5" TextTrimming="CharacterEllipsis"/>
                                        
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Прозрачность:" VerticalAlignment="Center" FontSize="12"/>
                                        <Slider Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Minimum="0" Maximum="1" Value="{Binding Opacity}" Margin="5,0"/>
                                        
                                        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Spacing="5" Margin="0,5,0,0">
                                            <ComboBox ItemsSource="{Binding Operations}" SelectedItem="{Binding BlendMode}" HorizontalAlignment="Stretch"/>
                                            <ComboBox ItemsSource="{Binding Channels}" SelectedItem="{Binding SelectedChannelMode}" HorizontalAlignment="Stretch"/>
                                            <ComboBox ItemsSource="{Binding MaskShapes}" SelectedItem="{Binding SelectedMaskShape}" HorizontalAlignment="Stretch"/>
                                        </StackPanel>
                                        
                                        <StackPanel Grid.Row="2" Grid.Column="2" Spacing="5" Margin="10,5,0,0" VerticalAlignment="Bottom">
                                            <Button Content="Удалить" Command="{Binding $parent[Window].DataContext.RemoveLayerCommand}" CommandParameter="{Binding}" Padding="10,2" Background="#8b0000" Foreground="White" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Button Grid.Row="2" Content="Сохранить результат..." Command="{Binding SaveResultCommand}" HorizontalAlignment="Stretch" Margin="0,15,0,0"/>

                <TextBlock Grid.Row="3" Text="{Binding LastOperationTime, StringFormat='{}Время выполнения: {0}'}" Foreground="Gray" FontSize="11" Margin="0,5,0,0" HorizontalAlignment="Left"/>
            </Grid>
        </Border>

        <!-- Result Panel -->
        <Grid Grid.Column="1" Background="#202020" RowDefinitions="*, 300">
            <Image Grid.Row="0" Source="{Binding ResultImage}" Stretch="Uniform" Margin="20"/>
            
            <!-- Panels Container -->
            <Grid Grid.Row="1" ColumnDefinitions="*, *" Margin="20,0,20,20">
                
                <!-- Hist/Curve Panel -->
                <Border Grid.Column="1" Background="#303030" Padding="15" CornerRadius="8" Margin="10,0,0,0">
                <Grid ColumnDefinitions="256, *">
                    <!-- Histogram and Curve Canvas -->
                    <Border Grid.Column="0" Width="256" Height="256" Background="Black" BorderBrush="Gray" BorderThickness="1">
                        <Canvas x:Name="GraphCanvas" Width="256" Height="256" Background="Transparent" ClipToBounds="True" PointerPressed="GraphCanvas_PointerPressed" PointerMoved="GraphCanvas_PointerMoved" PointerReleased="GraphCanvas_PointerReleased">
                            <Polygon Points="{Binding HistogramPoints}" Fill="#5588cc" Opacity="0.8" IsHitTestVisible="False"/>
                            <Polyline Points="{Binding CurvePoints}" Stroke="White" StrokeThickness="2" IsHitTestVisible="False"/>
                            <!-- Grid lines -->
                            <Line StartPoint="0,128" EndPoint="256,128" Stroke="#404040" StrokeThickness="1" IsHitTestVisible="False"/>
                            <Line StartPoint="128,0" EndPoint="128,256" Stroke="#404040" StrokeThickness="1" IsHitTestVisible="False"/>

                            <ItemsControl ItemsSource="{Binding EditorPoints}" IsHitTestVisible="False">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas Width="256" Height="256" Background="Transparent" IsHitTestVisible="False"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:CurvePointViewModel">
                                        <Grid IsHitTestVisible="False">
                                            <!-- Edge point: orange, larger -->
                                            <Ellipse Width="14" Height="14" Margin="-7,-7,0,0"
                                                     Fill="OrangeRed" Stroke="White" StrokeThickness="2"
                                                     IsVisible="{Binding IsEdge}" IsHitTestVisible="False"/>
                                            <!-- Mid point: blue-white -->
                                            <Ellipse Width="12" Height="12" Margin="-6,-6,0,0"
                                                     Fill="White" Stroke="DodgerBlue" StrokeThickness="2.5"
                                                     IsVisible="{Binding IsNotEdge}"
                                                     IsHitTestVisible="False"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                                <ItemsControl.Styles>
                                    <Style Selector="ContentPresenter" x:DataType="vm:CurvePointViewModel">
                                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                    </Style>
                                </ItemsControl.Styles>
                            </ItemsControl>
                        </Canvas>
                    </Border>
                    
                    <!-- Points Editor -->
                    <StackPanel Grid.Column="1" Margin="20,0,0,0" Spacing="6">
                        <TextBlock Text="Кривая градационного преобразования" Foreground="LightGray" FontWeight="Bold" FontSize="13"/>
                        
                        <Border Background="#1AFFFFFF" CornerRadius="5" Padding="10">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Левый клик на пустом месте — добавить точку" Foreground="#aaa" FontSize="11"/>
                                <TextBlock Text="Перетащить точку — изменить кривую" Foreground="#aaa" FontSize="11"/>
                                <TextBlock Text="Правый клик по точке — удалить" Foreground="#aaa" FontSize="11"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Текстовый ввод (X,Y):" Foreground="Gray" FontSize="12" Margin="0,4,0,0"/>
                        <TextBox Text="{Binding PointsText}" AcceptsReturn="True" Height="120" FontFamily="Consolas"/>
                        <TextBlock Text="* Кубическая сплайн-интерполяция" Foreground="#666" FontSize="11" FontStyle="Italic"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Fourier Panel -->
            <Border Grid.Row="1" Grid.Column="0" Background="#303030" Padding="15" CornerRadius="8" Margin="0,0,10,0">
                <Grid ColumnDefinitions="*, *">
                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="Фурье-образ (спектр)" Foreground="Gray" FontSize="12" Margin="0,0,0,5"/>
                        <Border Background="Black" BorderBrush="Gray" BorderThickness="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                            <Image Source="{Binding SpectrumImage}" Stretch="Uniform"/>
                        </Border>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <TextBlock Text="Маска фильтра" Foreground="Gray" FontSize="12" Margin="0,0,0,5"/>
                        <Border Background="Black" BorderBrush="Gray" BorderThickness="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                            <Image Source="{Binding MaskImage}" Stretch="Uniform"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            </Grid>

            <Border Grid.RowSpan="2" Background="#A0000000" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="20" CornerRadius="8" IsVisible="{Binding IsProcessing}">
                <StackPanel Spacing="10" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding ProcessingProgress, StringFormat='{}Пересчет изображения... {0:F0}%'}" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <ProgressBar IsIndeterminate="False" Value="{Binding ProcessingProgress}" Minimum="0" Maximum="100" Foreground="#1c75bc" Background="#333" Height="8" HorizontalAlignment="Stretch" MinWidth="200" CornerRadius="4"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
